{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "install.sh", "use": "@vercel/static" },
    { "src": "scripts/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/install.sh",              "dest": "/install.sh",              "headers": { "Content-Type": "text/plain; charset=utf-8" } },
    { "src": "/scripts/panel.sh",        "dest": "/scripts/panel.sh",        "headers": { "Content-Type": "text/plain; charset=utf-8" } },
    { "src": "/scripts/wings.sh",        "dest": "/scripts/wings.sh",        "headers": { "Content-Type": "text/plain; charset=utf-8" } },
    { "src": "/scripts/uninstall.sh",    "dest": "/scripts/uninstall.sh",    "headers": { "Content-Type": "text/plain; charset=utf-8" } },
    { "src": "/scripts/phpmyadmin.sh",   "dest": "/scripts/phpmyadmin.sh",   "headers": { "Content-Type": "text/plain; charset=utf-8" } },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}